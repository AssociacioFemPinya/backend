includes:
    - ./vendor/larastan/larastan/extension.neon

parameters:

    paths:
        - app/

    # Level 5 is a good balance between useful checks and false positives
    level: 5

    ignoreErrors:
        - '#Unsafe usage of new static\(\).#'

    excludePaths:
        - ./*/*/FileToBeExcluded.php
